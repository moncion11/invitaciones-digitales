{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/dashboard/**",
        "destination": "/dashboard/[token]/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}